@model IEnumerable<Product>
@{
    var categories = new List<string> { "Gym", "Yoga", "Chạy bộ", "Bóng đá", "Cầu lông" };
    var currentUrl = Context.Request.Path + Context.Request.QueryString;

    // SỬA ĐỔI TẠI ĐÂY: Thêm ?? 1 và ?? 5 để tránh lỗi biến bị Null gây sập ứng dụng
    string currentSort = ViewBag.CurrentSort;
    string currentSearch = ViewBag.CurrentSearch;
    string currentCategory = ViewBag.CurrentCategory;
    int pageNumber = ViewBag.PageNumber ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="container mt-4">
    <div class="card border-0 shadow-sm p-3 mb-4 bg-white rounded-4">
        <form asp-controller="Products" asp-action="Shop" method="get" class="row g-3 align-items-center">
            <input type="hidden" name="category" value="@currentCategory" />
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchString" value="@currentSearch" class="form-control bg-light border-0 py-2 shadow-none" placeholder="Tìm sản phẩm thể thao..." />
                    @if (!string.IsNullOrEmpty(currentSearch))
                    {
                        <a asp-controller="Products" asp-action="Shop" asp-route-category="@currentCategory" asp-route-sortOrder="@currentSort" class="btn btn-light text-muted border-0 d-flex align-items-center"><i class="bi bi-x-circle"></i></a>
                    }
                    <button type="submit" class="btn btn-dark px-4 fw-bold">TÌM</button>
                </div>
            </div>
            <div class="col-md-6 text-md-end d-flex justify-content-md-end align-items-center gap-2">
                <label class="text-muted small fw-bold text-uppercase mb-0"><i class="bi bi-sort-down"></i> Sắp xếp:</label>
                <select name="sortOrder" class="form-select bg-light border-0 py-2 shadow-none w-auto rounded-3 fw-semibold text-dark" onchange="this.form.submit()">
                    <!option value="" @(string.IsNullOrEmpty(currentSort) ? "selected" : "")>Mặc định (Tên A-Z)</!option>
                    <!option value="name_desc" @(currentSort == "name_desc" ? "selected" : "")>Tên ngược (Z-A)</!option>
                    <!option value="price_asc" @(currentSort == "price_asc" ? "selected" : "")>💰 Giá: Thấp đến Cao</!option>
                    <!option value="price_desc" @(currentSort == "price_desc" ? "selected" : "")>💰 Giá: Cao đến Thấp</!option>
                </select>
            </div>
        </form>
    </div>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm p-4 bg-white rounded-4 sticky-top" style="top: 90px; z-index: 10;">
                <h6 class="fw-bold text-dark border-bottom pb-2 mb-3 text-uppercase tracking-wider"><i class="bi bi-grid-3x3-gap"></i> Môn Thể Thao</h6>
                <div class="d-flex flex-column gap-2">
                    <a asp-controller="Products" asp-action="Shop"
                       asp-route-searchString="@currentSearch" asp-route-sortOrder="@currentSort"
                       class="btn text-start rounded-3 py-2 px-3 transition @(currentCategory == null ? "btn-dark fw-bold text-white shadow-sm" : "btn-light text-muted border-0")">
                        Tất cả thiết bị
                    </a>
                    @foreach (var cat in categories)
                    {
                        <a asp-controller="Products" asp-action="Shop"
                           asp-route-category="@cat" asp-route-searchString="@currentSearch" asp-route-sortOrder="@currentSort"
                           class="btn text-start rounded-3 py-2 px-3 transition @(currentCategory == cat ? "btn-dark fw-bold text-white shadow-sm" : "btn-light text-muted border-0")">
                             Đồ tập @cat
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="row">
                @if (!Model.Any())
                {
                    <div class="col-12 text-center my-5 py-5">
                        <i class="bi bi-search-heart text-muted" style="font-size: 4rem;"></i>
                        <h5 class="text-muted fw-bold mt-3">Không tìm thấy dụng cụ nào khớp bộ lọc!</h5>
                    </div>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <div class="col-md-4 mb-4">
                            <div class="card product-card shadow-sm h-100 p-3 bg-white border-0" style="border-radius: 16px;">

                                <div class="bg-light rounded-3 d-flex align-items-center justify-content-center p-3 mb-3" style="height: 180px; width: 100%;">
                                    <img src="@item.ImageUrl" class="mw-100 mh-100 object-fit-contain" alt="@item.Name" onerror="this.onerror=null; this.src='https://placehold.co/300x180?text=SportShop';" />
                                </div>

                                <span class="badge bg-secondary-subtle text-secondary mb-2 align-self-start border-0 px-2 py-1 small fw-bold text-uppercase">@item.Category</span>

                                <div style="min-height: 44px;" class="d-flex align-items-center mb-2">
                                    <h6 class="fw-bold text-dark m-0 fs-6 text-start lh-base text-truncate-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @item.Name
                                    </h6>
                                </div>

                                <div class="mt-auto">
                                    <h5 class="text-danger fw-bold text-start mb-3">@item.Price.ToString("N0") đ</h5>
                                    <div class="row g-1">
                                        <div class="col-5">
                                            <a asp-controller="Products" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary w-100 rounded-3 py-2 fw-semibold">Xem</a>
                                        </div>
                                        <div class="col-7">
                                            <a asp-controller="ShoppingCart" asp-action="AddToShoppingCart" asp-route-pId="@item.Id" asp-route-returnUrl="@currentUrl" class="btn btn-sm btn-warning w-100 fw-bold rounded-3 py-2"><i class="bi bi-cart-plus"></i> Chọn Mua</a>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                }
            </div>

            @if (totalPages > 1)
            {
                <nav class="d-flex justify-content-center mt-4">
                    <ul class="pagination pagination-md shadow-sm rounded-pill overflow-hidden border-0">
                        <li class="page-item @(ViewBag.HasPreviousPage == true ? "" : "disabled")">
                            <a class="page-item page-link text-dark border-0 px-3 py-2" asp-action="Shop" asp-route-category="@currentCategory" asp-route-searchString="@currentSearch" asp-route-sortOrder="@currentSort" asp-route-pageNumber="@(pageNumber - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == pageNumber ? "active" : "")">
                                <a class="page-link border-0 px-3.5 py-2 fw-bold @(i == pageNumber ? "bg-dark text-white shadow" : "text-dark bg-white")" asp-action="Shop" asp-route-category="@currentCategory" asp-route-searchString="@currentSearch" asp-route-sortOrder="@currentSort" asp-route-pageNumber="@i">
                                    @i
                                </a>
                            </li>
                        }
                        <li class="page-item @(ViewBag.HasNextPage == true ? "" : "disabled")">
                            <a class="page-item page-link text-dark border-0 px-3 py-2" asp-action="Shop" asp-route-category="@currentCategory" asp-route-searchString="@currentSearch" asp-route-sortOrder="@currentSort" asp-route-pageNumber="@(pageNumber + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
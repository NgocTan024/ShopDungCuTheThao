@model IEnumerable<Product>
@{
    var categories = new List<string> { "Gym", "Yoga", "Chạy bộ", "Bóng đá", "Cầu lông" };
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm p-4 bg-white rounded-4">
                <h5 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="bi bi-filter-left"></i> BỘ LỌC MÔN THỂ THAO</h5>
                <div class="d-flex flex-column gap-2">
                    <a asp-controller="Products" asp-action="Shop" class="btn text-start rounded-3 @(ViewBag.CurrentCategory == null ? "btn-dark fw-bold" : "btn-light text-muted")">Tất cả dụng cụ</a>
                    @foreach (var cat in categories)
                    {
                        <a asp-controller="Products" asp-action="Shop" asp-route-category="@cat" class="btn text-start rounded-3 @(ViewBag.CurrentCategory == cat ? "btn-dark fw-bold" : "btn-light text-muted")">🛒 Đồ tập @cat</a>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <h3 class="fw-bold mb-4 text-dark text-uppercase">Danh mục: @(ViewBag.CurrentCategory ?? "Tất cả thiết bị")</h3>
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card product-card shadow-sm h-100 p-3 bg-white">
                            <div class="bg-light rounded p-4 text-center mb-3 text-muted border-0" style="min-height: 140px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-trophy text-secondary fs-1"></i>
                            </div>
                            <span class="badge bg-secondary mb-2 align-self-start">@item.Category</span>
                            <h6 class="fw-bold text-dark text-truncate mb-1">@item.Name</h6>
                            <h5 class="text-primary fw-bold mt-2">@item.Price.ToString("N0") đ</h5>
                            <div class="row g-1 mt-3">
                                <div class="col-5"><a asp-controller="Products" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary w-100 rounded-3">Xem</a></div>
                                <div class="col-7"><a asp-controller="ShoppingCart" asp-action="AddToShoppingCart" asp-route-pId="@item.Id" asp-route-returnUrl="@currentUrl" class="btn btn-sm btn-warning w-100 fw-bold rounded-3"><i class="bi bi-cart-plus"></i> Chọn Mua</a></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
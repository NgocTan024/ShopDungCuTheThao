@model Product
@{
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="container mt-5 py-4">
    <div class="card border-0 shadow-sm p-4 bg-white rounded-4">
        <div class="row align-items-center">
            <div class="col-md-6 mb-4 mb-md-0">
                <div class="bg-light text-muted text-center rounded-4 p-5 d-flex align-items-center justify-content-center border-0 shadow-inner" style="min-height: 380px;">
                    <div>
                        <i class="bi bi-image-alt text-body-tertiary" style="font-size: 5rem;"></i>
                        <p class="mt-2 text-uppercase tracking-wider fw-semibold text-muted">Hình ảnh thiết bị chính hãng</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 ps-md-5">
                <span class="badge bg-success px-3 py-2 rounded-pill fs-6 mb-3"># @Model.Category</span>
                <h1 class="fw-bold text-dark lh-tight mb-2">@Model.Name</h1>
                <hr class="my-3 text-muted" />
                <h5 class="fw-bold text-secondary mb-2"><i class="bi bi-card-text"></i> Đặc tính & Tính năng kĩ thuật:</h5>
                <p class="text-muted fs-6 lh-relaxed">@Model.Detail</p>

                <div class="bg-danger-subtle rounded-3 p-3 my-4">
                    <span class="text-muted small text-uppercase fw-bold">Giá bán ưu đãi độc quyền:</span>
                    <h2 class="text-danger fw-bold mb-0 mt-1">@Model.Price.ToString("N0") VNĐ</h2>
                </div>

                <div class="d-grid gap-2">
                    <a asp-controller="ShoppingCart" asp-action="AddToShoppingCart" asp-route-pId="@Model.Id" asp-route-returnUrl="@currentUrl" class="btn btn-gradient btn-lg fw-bold py-3 rounded-pill shadow-sm"><i class="bi bi-cart-check-fill"></i> THÊM THIẾT BỊ VÀO GIỎ HÀNG</a>
                    <a asp-controller="Products" asp-action="Shop" class="btn btn-light btn-md rounded-pill mt-2 text-muted fw-bold"><i class="bi bi-arrow-left-short"></i> Tiếp tục xem sản phẩm khác</a>
                </div>
            </div>
        </div>
    </div>
</div>
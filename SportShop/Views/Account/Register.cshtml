@{
    Layout = "_Layout";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="card shadow border-0 rounded-4 p-4 p-sm-5 bg-white" style="max-width: 440px; width: 100%;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-dark text-uppercase" style="letter-spacing: 1px;"><span class="text-warning">SPORT</span>SHOP</h2>
            <p class="text-muted small">Tạo tài khoản mới để theo dõi đơn hàng và giỏ hàng</p>
        </div>

        <form asp-controller="Account" asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small border-0 rounded-3"></div>

            <div class="mb-3">
                <label class="form-label fw-bold text-muted small text-uppercase">Địa chỉ Email</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" class="form-control bg-light border-start-0 py-2 fs-6 text-dark shadow-none" placeholder="your-email@example.com" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-muted small text-uppercase">Mật khẩu mới</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" class="form-control bg-light border-start-0 py-2 fs-6 text-dark shadow-none" placeholder="Mật khẩu tối thiểu 6 ký tự" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-muted small text-uppercase">Xác nhận mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-shield-lock"></i></span>
                    <input type="password" name="confirmPassword" class="form-control bg-light border-start-0 py-2 fs-6 text-dark shadow-none" placeholder="Nhập lại mật khẩu phía trên" required />
                </div>
            </div>

            <button type="submit" class="btn btn-gradient w-100 btn-lg fw-bold py-2.5 rounded-pill shadow-sm mb-2">
                <i class="bi bi-person-plus me-1"></i> TẠO TÀI KHOẢN MỚI
            </button>

            <div class="text-center mt-3">
                <span class="text-muted small">Bạn đã có tài khoản rồi?</span>
                <a asp-controller="Account" asp-action="Login" class="text-decoration-none small fw-bold text-primary ms-1">Đăng nhập tại đây</a>
            </div>
        </form>
    </div>
</div>
@model IEnumerable<Product>
@{
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="bg-dark text-white py-5 position-relative mb-5 text-center" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1517838277536-f5f99be501cd?q=80&w=1500') center/cover;">
    <div class="container py-5">
        <span class="badge bg-warning text-dark fw-bold mb-3 px-3 py-2 text-uppercase">New Season Aesthetics</span>
        <h1 class="display-3 fw-bold tracking-tight">NÂNG TẦM SỨC MẠNH CỦA BẠN</h1>
        <p class="lead text-light border-0 my-3">Trang thiết bị thể thao đỉnh cao nâng tầm hiệu suất tập luyện.</p>
        <a asp-controller="Products" asp-action="Shop" class="btn btn-gradient btn-lg fw-bold px-5 py-3 rounded-pill mt-3 shadow">KHÁM PHÁ CỬA HÀNG</a>
    </div>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-end border-bottom pb-3 mb-4">
        <h2 class="fw-bold text-dark mb-0">🔥 SẢN PHẨM BÁN CHẠY XU HƯỚNG</h2>
        <a asp-controller="Products" asp-action="Shop" class="text-primary fw-bold text-decoration-none">Xem tất cả <i class="bi bi-arrow-right"></i></a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card product-card shadow-sm h-100 p-3 bg-white border-0" style="border-radius: 16px;">

                    <div class="bg-light rounded-3 d-flex align-items-center justify-content-center p-3 mb-3" style="height: 220px; width: 100%;">
                        <img src="@item.ImageUrl" class="mw-100 mh-100 object-fit-contain" alt="@item.Name" onerror="this.onerror=null; this.src='https://placehold.co/300x220?text=SportShop';" />
                    </div>

                    <span class="badge bg-danger-subtle text-danger fw-bold mb-2 align-self-start px-2.5 py-1">BEST SELLER</span>

                    <div style="min-height: 46px;" class="d-flex align-items-center mb-1">
                        <h5 class="fw-bold text-dark m-0 fs-5 text-start lh-base text-truncate-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @item.Name
                        </h5>
                    </div>

                    <div style="min-height: 40px;" class="mb-2">
                        <p class="text-muted small text-start m-0" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">
                            @item.Detail
                        </p>
                    </div>

                    <div class="mt-auto">
                        <div class="text-start mb-3">
                            <span class="text-danger fw-bold fs-4">@item.Price.ToString("N0") đ</span>
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <a asp-controller="Products" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-outline-dark btn-sm w-100 rounded-pill py-2 fw-semibold">Chi tiết</a>
                            </div>
                            <div class="col-6">
                                <a asp-controller="ShoppingCart" asp-action="AddToShoppingCart" asp-route-pId="@item.Id" asp-route-returnUrl="@currentUrl" class="btn btn-dark btn-sm w-100 rounded-pill py-2 fw-semibold"><i class="bi bi-bag-plus"></i> + Giỏ</a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>
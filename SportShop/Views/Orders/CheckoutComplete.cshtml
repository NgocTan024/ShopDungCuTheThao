@{
    Layout = "_Layout";

    string orderIdStr = Context.Request.Query["orderId"].ToString();
    string amountStr = Context.Request.Query["amount"].ToString();
    string method = Context.Request.Query["method"].ToString();

    int orderId = !string.IsNullOrEmpty(orderIdStr) ? int.Parse(orderIdStr) : 0;
    decimal amount = !string.IsNullOrEmpty(amountStr) ? decimal.Parse(amountStr, System.Globalization.CultureInfo.InvariantCulture) : 0;
    if (string.IsNullOrEmpty(method)) { method = "COD"; }

    string bankId = "MB";
    string accountNo = "2860123456";
    string accountName = "NGUYEN VAN A";
    string description = $"SPORTSHOP {orderId}";

    string qrCodeUrl = $"https://img.vietqr.io/image/{bankId}-{accountNo}-compact.png?amount={amount:0}&addInfo={Uri.EscapeDataString(description)}&accountName={Uri.EscapeDataString(accountName)}";
}

<div class="container mt-5" style="max-width: 800px;">
    <div class="card border-0 shadow-sm p-4 p-sm-5 bg-white rounded-4 text-center text-dark">

        <div id="orderPendingHeader">
            <div class="mb-3">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4.5rem;"></i>
            </div>
            <h2 class="fw-bold text-success mb-2">ĐẶT HÀNG THÀNH CÔNG!</h2>
            <p class="text-muted mb-4">Mã đơn hàng của bạn: <span class="text-dark fw-bold">#@orderId</span></p>
        </div>

        <div id="orderSuccessHeader" style="display: none;">
            <div class="mb-3">
                <div class="spinner-border text-success mb-2" id="paymentSpinner" role="status" style="width: 3rem; height: 3rem; display: none;"></div>
                <i class="bi bi-shield-fill-check text-success" id="successIcon" style="font-size: 4.5rem;"></i>
            </div>
            <h2 class="fw-bold text-success mb-2">ĐÃ THANH TOÁN</h2>
            <p class="text-muted">Hệ thống đã xác nhận giao dịch thành công cho đơn hàng <strong class="text-dark">#@orderId</strong>.</p>
            <div class="badge bg-success-subtle text-success px-3 py-2 rounded-3 fw-bold mb-4">Trạng thái: Đang chuẩn bị hàng chuyển đi</div>
        </div>

        @if (method == "BANK_QR" || method == "bank_qr")
        {
            <div id="paymentContentArea" class="row align-items-center text-start g-4 border-top pt-4">
                <div class="col-md-6">
                    <h6 class="fw-bold text-dark mb-3 text-uppercase small tracking-wide">Thông tin chuyển khoản</h6>
                    <div class="bg-light p-3 rounded-3 mb-3" style="font-size: 0.9rem;">
                        <div class="mb-2"><span class="text-muted">Ngân hàng:</span> <strong class="text-dark">@bankId (Ngân hàng Quân Đội)</strong></div>
                        <div class="mb-2"><span class="text-muted">Số tài khoản:</span> <strong class="text-primary fs-5">@accountNo</strong></div>
                        <div class="mb-2"><span class="text-muted">Chủ tài khoản:</span> <strong class="text-dark">@accountName</strong></div>
                        <div class="mb-2"><span class="text-muted">Số tiền:</span> <strong class="text-danger fs-5">@amount.ToString("N0") đ</strong></div>
                        <div><span class="text-muted">Nội dung ghi chú:</span> <strong class="text-dark bg-warning-subtle px-2 py-0.5 rounded">@description</strong></div>
                    </div>

                    <button type="button" id="btnConfirmPayment" class="btn btn-success w-100 py-2.5 fw-bold rounded-3 shadow-sm text-uppercase mb-2" style="font-size: 0.9rem;">
                        Tôi đã thanh toán
                    </button>
                </div>

                <div class="col-md-6 text-center border-start border-light-subtle d-flex flex-column align-items-center">
                    <div class="p-2 bg-white border rounded-3 shadow-sm mb-2" style="max-width: 220px;">
                        <img src="@qrCodeUrl" class="img-fluid w-100" alt="Mã QR Chuyển Khoản" />
                    </div>
                    <small class="text-muted" style="font-size: 0.8rem;"><i class="bi bi-qr-code-scan"></i> Mở App Ngân hàng quét mã để điền nhanh</small>
                </div>
            </div>
        }
        else
        {
            <div class="mb-3">
                <i class="bi bi-clock-history text-warning" style="font-size: 4.5rem;"></i>
            </div>
            <h2 class="fw-bold text-dark mb-2">CHỜ THANH TOÁN</h2>
            <p class="text-muted">Đơn hàng <span class="text-dark fw-bold">#@orderId</span> đã được khởi tạo và ghi nhận thành công.</p>

            <div class="bg-light p-4 rounded-3 text-start mb-3 mt-4" style="font-size: 0.95rem;">
                <div class="mb-2"><span class="text-muted">Hình thức xử lý:</span> <strong class="text-dark">Nhận hàng trả tiền mặt (COD)</strong></div>
                <div class="mb-2"><span class="text-muted">Số tiền cần thanh toán:</span> <strong class="text-danger fs-5">@amount.ToString("N0") đ</strong></div>
                <div class="text-muted small border-top pt-2 mt-2 lh-base">
                    Nhân viên bưu tá sẽ gọi điện giao hàng đến địa chỉ của bạn sau 2-4 ngày. Bạn vui lòng chuẩn bị đúng số tiền trên để hoàn tất thanh toán khi nhận bưu kiện.
                </div>
            </div>
        }

        <div class="d-flex gap-2 mt-4 justify-content-center border-top pt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-light border rounded-3 px-4 fw-semibold py-2">Quay lại trang chủ</a>
            <a asp-controller="Orders" asp-action="MyOrders" class="btn btn-outline-dark rounded-3 px-4 fw-semibold py-2">Xem đơn đã đặt</a>
        </div>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const btnConfirm = document.getElementById("btnConfirmPayment");
        const orderPendingHeader = document.getElementById("orderPendingHeader");
        const orderSuccessHeader = document.getElementById("orderSuccessHeader");
        const paymentContentArea = document.getElementById("paymentContentArea");
        const paymentSpinner = document.getElementById("paymentSpinner");
        const successIcon = document.getElementById("successIcon");

        if (btnConfirm) {
            btnConfirm.addEventListener("click", function () {
                // 1. Chuyển đổi giao diện sang chế độ kiểm tra Loading
                paymentContentArea.style.display = "none";
                orderPendingHeader.style.display = "none";
                orderSuccessHeader.style.display = "block";
                successIcon.style.display = "none";
                paymentSpinner.style.display = "inline-block";

                // 2. Gửi lệnh AJAX POST về server để thay đổi trạng thái trong CSDL SQL Server
                fetch('/Orders/ConfirmPayment?orderId=' + @orderId, {
                    method: 'POST'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Nếu database lưu ngon lành, tắt loading và hiện hình chiếc khiên ĐÃ THANH TOÁN
                        setTimeout(function () {
                            paymentSpinner.style.display = "none";
                            successIcon.style.display = "inline-block";
                        }, 1000);
                    } else {
                        alert("Lỗi: " + data.message);
                    }
                })
                .catch(err => {
                    console.error("Lỗi kết nối:", err);
                    alert("Không thể kết nối đến máy chủ hệ thống!");
                });
            });
        }
    });
</script>
@model IEnumerable<Order>

<div class="container mt-5" style="max-width: 900px;">
    <h2 class="fw-bold text-dark border-bottom pb-3 mb-4"><i class="bi bi-clock-history"></i> ĐƠN HÀNG CỦA TÔI</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white shadow-sm rounded-4 card border-0">
            <i class="bi bi-receipt text-muted" style="font-size: 5rem;"></i>
            <h4 class="text-muted fw-bold mt-3">Bạn chưa đặt mua đơn hàng nào!</h4>
            <a asp-controller="Products" asp-action="Shop" class="btn btn-dark mt-3 rounded-pill px-5 py-2.5 fw-bold">MUA SẮM NGAY</a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4 bg-white p-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center border-bottom pb-2 mb-3">
                    <div>
                        <span class="text-muted small">Mã đơn:</span> <strong class="text-dark">#@order.Id</strong>
                        <span class="text-muted mx-2">|</span>
                        <span class="text-muted small">Ngày mua:</span> <span class="text-dark">@order.OrderPlaced.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div>
                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-bold small">
                            <i class="bi bi-check2-circle"></i> @order.Status
                        </span>
                    </div>
                </div>

                <div class="row align-items-center">
                    <div class="col-md-7 mb-3 mb-md-0">
                        <h6 class="fw-bold text-secondary mb-2"><i class="bi bi-box-seam"></i> Danh sách dụng cụ:</h6>
                        <ul class="list-unstyled mb-0">
                            @foreach (var detail in order.OrderDetails!)
                            {
                                <li class="mb-1 text-dark small">
                                    📦 <strong>@detail.Product?.Name</strong> — <span class="text-muted">SL:</span> <span class="badge bg-light text-dark border">@detail.Quantity</span> x @detail.Price.ToString("N0") đ
                                </li>
                            }
                        </ul>
                    </div>
                    <div class="col-md-5 text-md-end bg-light p-3 rounded-3 border-0">
                        <span class="text-muted small d-block">Hình thức: <strong>@order.PaymentMethod</strong></span>
                        <span class="text-muted small d-block text-truncate">Giao tới: <em>@order.Address</em></span>
                        <h5 class="text-danger fw-bold mt-2 mb-0">Tổng tiền: @order.OrderTotal.ToString("N0") đ</h5>
                    </div>
                </div>
            </div>
        }
    }
</div>
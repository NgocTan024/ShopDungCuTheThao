@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<div class="d-flex align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        <span class="text-light me-2 small">
            <i class="bi bi-person-circle text-warning me-1"></i> Xin chào, @UserManager.GetUserName(User)
        </span>
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold">
                <i class="bi bi-box-arrow-right"></i> Đăng xuất
            </button>
        </form>
    }
    else
    {
        <a class="btn btn-outline-warning btn-sm rounded-pill px-3 fw-bold" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
        <a class="btn btn-warning btn-sm rounded-pill px-3 fw-bold text-dark" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
    }
</div>
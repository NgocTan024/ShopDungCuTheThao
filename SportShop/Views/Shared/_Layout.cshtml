<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SportShop - Hệ Thống Dụng Cụ Thể Thao Cao Cấp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8f9fa;
        }

        .product-card {
            transition: transform 0.2s, box-shadow 0.2s;
            border: none;
            border-radius: 12px;
        }

            .product-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
            }

        .btn-gradient {
            background: linear-gradient(135deg, #ff4e50, #f9d423);
            border: none;
            color: white;
        }

            .btn-gradient:hover {
                opacity: 0.9;
                color: white;
            }

        /* Chỉnh thanh tìm kiếm góc vuông mềm (rounded-3) nhìn thuôn dài */
        .nav-search-input {
            transition: all 0.2s;
        }

            .nav-search-input:focus {
                background-color: #ffffff !important;
                color: #000000 !important;
                border-color: #ffc107 !important;
            }

        /* Hộp gợi ý sản phẩm bo góc đồng bộ */
        .suggestion-box {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            z-index: 9999;
            display: none;
            border: 1px solid #e9ecef;
            overflow: hidden;
            margin-top: 5px;
        }

        .suggestion-item {
            display: flex;
            align-items: center;
            padding: 10px 15px;
            text-decoration: none;
            color: #333;
            transition: background 0.15s;
            border-bottom: 1px solid #f1f3f5;
        }

            .suggestion-item:last-child {
                border-bottom: none;
            }

            .suggestion-item:hover {
                background: #f8f9fa;
                color: #000;
            }
    </style>
</head>
<body>
    <header class="sticky-top shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold fs-3 text-uppercase tracking-wider me-4" asp-controller="Home" asp-action="Index">
                    <span class="text-warning">Sport</span>Shop
                </a>

                <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"></button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <div class="d-none d-lg-block position-relative me-auto" style="max-width: 450px; width: 100%;">
                        <form asp-controller="Products" asp-action="Shop" method="get">
                            <div class="input-group">
                                <input type="text" id="globalSearchInput" name="searchString" autocomplete="off"
                                       class="form-control nav-search-input bg-dark text-white border-secondary rounded-3 ps-3 shadow-none py-2"
                                       placeholder="Tìm kiếm dụng cụ thể thao..." style="font-size: 0.85rem; border-top-right-radius: 0 !important; border-bottom-right-radius: 0 !important;" />
                                <button type="submit" class="btn btn-warning border-0 rounded-3 px-3" style="border-top-left-radius: 0 !important; border-bottom-left-radius: 0 !important;">
                                    <i class="bi bi-search text-dark"></i>
                                </button>
                            </div>
                        </form>
                        <div id="suggestionBox" class="suggestion-box"></div>
                    </div>

                    <ul class="navbar-nav mb-2 mb-lg-0 fs-6 me-auto px-2">
                        <li class="nav-item"><a class="nav-link text-white px-3 fw-semibold" asp-controller="Home" asp-action="Index">Trang Chủ</a></li>
                        <li class="nav-item"><a class="nav-link text-white px-3 fw-semibold" asp-controller="Products" asp-action="Shop">Cửa Hàng</a></li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.Identity.Name == "admin@gmail.com"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold px-3" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-shield-lock-fill"></i> Quản Trị
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2 border-start border-secondary ps-3">
                        <a class="btn btn-outline-light position-relative rounded-3 px-3 py-2 small fw-semibold" asp-controller="ShoppingCart" asp-action="Index" style="font-size: 0.9rem;">
                            <i class="bi bi-cart3 me-1"></i> Giỏ hàng
                            @if (Context.Session.GetInt32("CartCount") > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    @Context.Session.GetInt32("CartCount")
                                </span>
                            }
                        </a>
                        <partial name="_LoginPartial" />
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white pt-5 pb-3 mt-5">
        <div class="container text-center">
            <p class="fw-bold mb-1"> SPORTSHOP - ĐẠI SIÊU THỊ THỂ THAO THỰC THỤ</p>
            <p class="text-muted small">Hệ thống phân phối dụng cụ Gym, Yoga, Chạy bộ, Bóng đá chính hãng toàn quốc.</p>
            <hr class="border-secondary my-4" />
            <p class="text-muted small mb-0">&copy; 2026 SportShop Ecosystem. Built beautifully for performance.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("globalSearchInput");
            const suggestionBox = document.getElementById("suggestionBox");

            if (!searchInput || !suggestionBox) return;

            searchInput.addEventListener("input", function () {
                const query = this.value.trim();

                if (query.length < 1) {
                    suggestionBox.style.display = "none";
                    suggestionBox.innerHTML = "";
                    return;
                }

                fetch(`/Products/GetSuggestions?term=${encodeURIComponent(query)}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.length === 0) {
                            suggestionBox.style.display = "none";
                            return;
                        }

                        let htmlContent = "";
                        data.forEach(item => {
                            htmlContent += `
                                <a href="/Products/Detail/${item.id}" class="suggestion-item">
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center border me-3" style="width: 40px; height: 40px; overflow: hidden; flex-shrink: 0;">
                                        <img src="${item.imageUrl}" style="max-width:100%; max-height:100%; object-fit: contain;" onerror="this.src='https://placehold.co/40x40?text=Sport';">
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="fw-bold text-dark text-truncate small mb-0">${item.name}</div>
                                        <span class="badge bg-secondary-subtle text-secondary small" style="font-size: 0.7rem;">${item.category}</span>
                                    </div>
                                    <div class="text-danger fw-bold small ms-2">${item.price}</div>
                                </a>
                            `;
                        });

                        suggestionBox.innerHTML = htmlContent;
                        suggestionBox.style.display = "block";
                    })
                    .catch(err => console.error("Lỗi hệ thống gợi ý:", err));
            });

            document.addEventListener("click", function (e) {
                if (!searchInput.contains(e.target) && !suggestionBox.contains(e.target)) {
                    suggestionBox.style.display = "none";
                }
            });
        });
    </script>
</body>
</html>